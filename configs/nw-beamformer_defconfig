# Boot support
CONFIG_BOOTFILE="Image"
CONFIG_BOOTCOMMAND="bridge enable ; dhcp ; bootm"
CONFIG_QSPI_BOOT=y
CONFIG_BOOTDELAY=5
CONFIG_USE_BOOTARGS=y
CONFIG_HUSH_PARSER=y
CONFIG_USE_BOOTCOMMAND=y
CONFIG_BOOTARGS="earlycon panic=-1 initrd=initrd console=ttyS1,115200 loglevel=4"


# Disable support for NAND
CONFIG_NAND_BOOT=n
CONFIG_SPL_NAND_SUPPORT=n
