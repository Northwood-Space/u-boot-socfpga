# Useful debugging
CONFIG_CMD_DHCP=y
CONFIG_CMD_WGET=y
CONFIG_CMD_DNS=n

# Load over serial
CONFIG_CMD_LOADB=y

CONFIG_LZO=y

# Ethernet Phy Configuration
CONFIG_DM_ETH_PHY=y
CONFIG_DM_MDIO=y

# Enable extra flash devices
CONFIG_SPI_FLASH_MACRONIX=y
CONFIG_SPI_FLASH_GIGADEVICE=y
CONFIG_SPI_FLASH_WINBOND=y

# Enable secure monitor call
# this is used to grab the chip id
CONFIG_CMD_SMC=y

# Enable our custom shit because we're sick.
CONFIG_CMD_NORTHWOOD=y

# Enable Power On Self Test (POST)
#
# This is broken do not enable.
CONFIG_POST=n

# UBoot env setup
#
# we are storing our u-boot environment in qspi
CONFIG_ENV_IS_IN_SPI_FLASH=y
CONFIG_ENV_UBI_PART="u-boot"
CONFIG_ENV_UBI_VOLUME="env"
# check the device: from the output of
# Beamformer UBoot λ mtd list
# - parent: spi@ff8d2000
# - driver: jedec_spi_nor
# - path: /soc/spi@ff8d2000/flash@0
# - type: NOR flash
# - block size: 0x10000 bytes
# - min I/O: 0x1 bytes
# - 0x000000000000-0x000010000000 : "nor0"
#         - 0x000000000000-0x000002800000 : "u-boot"
CONFIG_MTDIDS_DEFAULT="nor0=flash@0"
CONFIG_MTDPARTS_DEFAULT="mtdparts=flash@0:40m(u-boot)"
CONFIG_ENV_OVERWRITE=y

